<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="perseverance">

    <!-- Base link: chassis, mass 1025 kg, IMU + all cameras/LIDAR/contact -->
    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0.8 0 0 0</pose>
        <mass>1025</mass>
        <inertia>
          <ixx>10</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>25</iyy><iyz>0</iyz>
          <izz>20</izz>
        </inertia>
      </inertial>
      <collision name="base_link_collision">
        <geometry>
          <box><size>1.2 1.0 0.6</size></box>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.5</mu><mu2>1.0</mu2></ode>
          </friction>
        </surface>
      </collision>
      <!-- Box visual so sim loads without mesh; add resources/perseverance.dae for real rover mesh -->
      <visual name="base_visual">
        <geometry>
          <box><size>1.2 1.0 0.6</size></box>
        </geometry>
      </visual>

      <!-- Existing IMU (50 Hz, Gaussian noise) -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev><bias_mean>7.5e-06</bias_mean><bias_stddev>8e-07</bias_stddev><dynamic_bias_stddev>4e-07</dynamic_bias_stddev><dynamic_bias_correlation_time>1000</dynamic_bias_correlation_time></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev><bias_mean>7.5e-06</bias_mean><bias_stddev>8e-07</bias_stddev><dynamic_bias_stddev>4e-07</dynamic_bias_stddev><dynamic_bias_correlation_time>1000</dynamic_bias_correlation_time></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev><bias_mean>7.5e-06</bias_mean><bias_stddev>8e-07</bias_stddev><dynamic_bias_stddev>4e-07</dynamic_bias_stddev><dynamic_bias_correlation_time>1000</dynamic_bias_correlation_time></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev><dynamic_bias_stddev>0.002</dynamic_bias_stddev><dynamic_bias_correlation_time>300</dynamic_bias_correlation_time></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev><dynamic_bias_stddev>0.002</dynamic_bias_stddev><dynamic_bias_correlation_time>300</dynamic_bias_correlation_time></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev><dynamic_bias_stddev>0.002</dynamic_bias_stddev><dynamic_bias_correlation_time>300</dynamic_bias_correlation_time></noise></z>
          </linear_acceleration>
        </imu>
        <topic>/rover/imu</topic>
      </sensor>

      <!-- === NAVCAM (Front Stereo Camera) === -->
      <sensor name="navcam_left" type="camera">
        <pose>0.5 0.15 1.5 0 0.2 0</pose>
        <always_on>1</always_on>
        <update_rate>15</update_rate>
        <camera name="navcam_left">
          <horizontal_fov>1.3962634</horizontal_fov>
          <image>
            <width>1280</width>
            <height>960</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>0.1</near><far>500</far></clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <topic>/rover/navcam_left</topic>
      </sensor>

      <!-- === HAZCAM FRONT (Obstacle Detection) === -->
      <sensor name="hazcam_front" type="depth_camera">
        <pose>0.8 0 0.4 0 0.5 0</pose>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <camera name="hazcam_front">
          <horizontal_fov>2.0944</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip><near>0.05</near><far>20</far></clip>
        </camera>
        <topic>/rover/hazcam_front</topic>
      </sensor>

      <!-- === HAZCAM REAR === -->
      <sensor name="hazcam_rear" type="depth_camera">
        <pose>-0.8 0 0.4 0 0.5 3.14159</pose>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <camera name="hazcam_rear">
          <horizontal_fov>2.0944</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip><near>0.05</near><far>20</far></clip>
        </camera>
        <topic>/rover/hazcam_rear</topic>
      </sensor>

      <!-- === MASTCAM (High-res Science Camera on Mast) === -->
      <sensor name="mastcam" type="camera">
        <pose>0.3 0 2.0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>5</update_rate>
        <camera name="mastcam">
          <horizontal_fov>0.2967</horizontal_fov>
          <image>
            <width>1600</width>
            <height>1200</height>
            <format>R8G8B8</format>
          </image>
          <clip><near>1.0</near><far>2000</far></clip>
        </camera>
        <topic>/rover/mastcam</topic>
      </sensor>

      <!-- === SUPERCAM LIDAR === -->
      <sensor name="supercam_lidar" type="gpu_lidar">
        <pose>0.3 0 2.1 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>16</samples>
              <resolution>1</resolution>
              <min_angle>-0.26</min_angle>
              <max_angle>0.26</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>100</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0</mean>
            <stddev>0.02</stddev>
          </noise>
        </lidar>
        <topic>/rover/lidar</topic>
        <visualize>true</visualize>
      </sensor>

      <!-- === CONTACT SENSOR (Wheel Ground Contact) === -->
      <sensor name="wheel_contact" type="contact">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <contact>
          <collision>base_link_collision</collision>
        </contact>
        <topic>/rover/contact</topic>
      </sensor>
    </link>

    <!-- Left wheels (y forward, x right, z up; left side at x=1.07) -->
    <link name="left_wheel1">
      <pose>1.07 1.14 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="left_wheel1_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="left_wheel1_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>
    <link name="left_wheel2">
      <pose>1.2 0.08 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="left_wheel2_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="left_wheel2_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>
    <link name="left_wheel3">
      <pose>1.07 -1.07 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="left_wheel3_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="left_wheel3_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Right wheels (at x=-1.07) -->
    <link name="right_wheel1">
      <pose>-1.07 1.14 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="right_wheel1_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="right_wheel1_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>
    <link name="right_wheel2">
      <pose>-1.2 0.08 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="right_wheel2_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="right_wheel2_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>
    <link name="right_wheel3">
      <pose>-1.07 -1.07 0.26 0 0 0</pose>
      <inertial><mass>10</mass><inertia><ixx>0.1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.1</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
      <collision name="right_wheel3_collision">
        <pose>0 0 0 0 1.5707963267948966 0</pose>
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.5</mu><mu2>1.0</mu2>
              <slip1>0.00092</slip1><slip2>0</slip2>
              <fdir1>0 0 1</fdir1>
            </ode>
          </friction>
          <contact>
            <ode><kp>1e7</kp><kd>1</kd></ode>
          </contact>
        </surface>
      </collision>
      <visual name="right_wheel3_visual">
        <geometry><cylinder><radius>0.27</radius><length>0.33</length></cylinder></geometry>
      </visual>
    </link>

    <!-- Revolute joints: parent base_link, child wheel, axis Y for rolling -->
    <joint name="left_wheel1_j" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel1</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>
    <joint name="left_wheel2_j" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel2</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>
    <joint name="left_wheel3_j" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel3</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>
    <joint name="right_wheel1_j" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel1</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>
    <joint name="right_wheel2_j" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel2</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>
    <joint name="right_wheel3_j" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel3</child>
      <axis><xyz expressed_in="__model__">0 1 0</xyz></axis>
      <limit><lower>-1e16</lower><upper>1e16</upper></limit>
    </joint>

    <!-- === DIFFERENTIAL DRIVE PLUGIN === -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel1_j</left_joint>
      <left_joint>left_wheel2_j</left_joint>
      <left_joint>left_wheel3_j</left_joint>
      <right_joint>right_wheel1_j</right_joint>
      <right_joint>right_wheel2_j</right_joint>
      <right_joint>right_wheel3_j</right_joint>
      <wheel_separation>2.14</wheel_separation>
      <wheel_radius>0.27</wheel_radius>
      <max_linear_acceleration>0.5</max_linear_acceleration>
      <min_linear_acceleration>-0.5</min_linear_acceleration>
      <max_angular_acceleration>0.3</max_angular_acceleration>
      <min_angular_acceleration>-0.3</min_angular_acceleration>
      <topic>/rover/cmd_vel</topic>
      <odom_topic>/rover/odometry</odom_topic>
      <tf_topic>/rover/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
    </plugin>

    <!-- === JOINT STATE PUBLISHER === -->
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/rover/joint_states</topic>
    </plugin>

  </model>
</sdf>
