###############################################
# HERMES MARS ROVER – Example Environment File
#
# Copy this file to `.env` and fill in values.
# Never commit your real secrets to git.
###############################################

########################
# LLM / Reasoning APIs #
########################

# Primary OpenRouter key (if using OpenRouter as router)
# Used by Hermes Agent for general reasoning.
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Direct OpenAI / OpenAI-compatible key (for tools that talk
# to an OpenAI-style API endpoint, including voice tools).
OPENAI_API_KEY=sk-your-openai-or-compatible-key

# Base URL for OpenAI-compatible APIs.
# - For OpenAI: https://api.openai.com/v1
# - For local/other: e.g. http://localhost:8000/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Voice tools can either use OPENAI_API_KEY or a dedicated key.
# If set, this overrides OPENAI_API_KEY for voice transcription/TTS.
VOICE_TOOLS_OPENAI_KEY=${OPENAI_API_KEY}

# Optional: nudge Hermes to think more or less deeply.
# Typical values: low, medium, high
HERMES_REASONING_EFFORT=medium


###############
# Telegram    #
###############

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Comma-separated list of numeric Telegram user IDs
# that are allowed to control the rover.
TELEGRAM_ALLOWED_USERS=123456789

# Optional: a home channel/chat ID where status updates
# and media can be broadcast.
TELEGRAM_HOME_CHANNEL=123456789


##########################
# API / Bridge / Rover   #
##########################

# FastAPI rover API base URL (from the VPS or local machine).
API_URL=http://localhost:8000

# Sensor/command bridge URL (Gazebo/ROS bridge, default :8765).
BRIDGE_URL=http://localhost:8765

# Shared secret used by API clients (Hermes, dashboard, etc.).
ROVER_API_KEY=your-secure-api-key-here


##########################
# External Integrations  #
##########################

# Firecrawl – used for research/web crawling skills (optional).
FIRECRAWL_API_KEY=fc-xxxxx

# Fal.ai – used for image/video generation tools (optional).
FAL_KEY=fal-xxxxx

# ElevenLabs – used for high-quality TTS voice output (optional).
ELEVENLABS_API_KEY=elevenlabs-xxxxx

# Supabase – backing store for dashboard persistence (optional).
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyxxxxx


##########################
# Gazebo / ROS / Tunnel  #
##########################

# Where Gazebo will look for the Perseverance model and other assets.
# Usually points at ./simulation/models inside this repo.
GZ_SIM_RESOURCE_PATH=./simulation/models

# ROS 2 domain ID to avoid collisions with other systems.
ROS_DOMAIN_ID=42

# Public domain/host used by tunneling (e.g. for Apple Watch or remote access).
TUNNEL_DOMAIN=rover.yourdomain.com


##########################
# Simulation Behavior    #
##########################

# Which world to use; for example:
# - mars_terrain.sdf
# - mars_terrain_websocket.sdf
HERMES_SIM_WORLD=mars_terrain_websocket.sdf

# If true, run only the simulation server (no GUI).
HERMES_SIM_SERVER_ONLY=true

# If true, use headless rendering for cameras/sensors.
HERMES_SIM_HEADLESS_RENDERING=true

# If true, run the sim in real time; false for accelerated.
HERMES_SIM_REALTIME=true

# Verbosity level for sim logging: 0–4 (higher = more logs).
HERMES_SIM_VERBOSITY=2

